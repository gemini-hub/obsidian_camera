{
  "name": "obsidian-camera",
  "version": "2.0.0",
  "description": "Camera plugin for Obsidian - take photos and record videos",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit -p tsconfig.json && node esbuild.config.mjs production",
    "build:fast": "node esbuild.config.mjs production"
  },
  "devDependencies": {
    "@types/node": "^16.11.6",
    "builtin-modules": "^3.3.0",
    "esbuild": "0.17.3",
    "obsidian": "latest",
    "typescript": "4.7.4"
  }
}
